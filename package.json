{
  "name": "@tegroton/tegro-finance",
  "version": "0.2.0",
  "description": "Minimal, production-ready Tegro Finance DEX integration for TON: typed read client (pools/assets/tokens) + swap & liquidity quote/build helpers + TON Connect message adapter. The wallet signs; the SDK never touches keys.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "example:pools": "tsx examples/list-pools.ts",
    "example:swap": "tsx examples/quote-and-swap.ts"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "tegro",
    "tegro-finance",
    "dex",
    "ton",
    "the-open-network",
    "amm",
    "swap",
    "liquidity",
    "ton-connect",
    "defi",
    "tegroton"
  ],
  "author": "TegroTON",
  "license": "MIT",
  "homepage": "https://github.com/TegroTON/tegro-finance-sdk#readme",
  "bugs": {
    "url": "https://github.com/TegroTON/tegro-finance-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TegroTON/tegro-finance-sdk.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@tonconnect/ui": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@tonconnect/ui": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ton/core": "^0.60.1"
  }
}
